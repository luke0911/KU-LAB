<?xml version="1.0" encoding="utf-8"?>
<!--EditText 상태(포커스 여부)에 따른 배경 스타일 정의-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <stroke android:width="1dp" android:color="#999999"/> <corners android:radius="8dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <stroke android:width="1dp" android:color="#33000000"/> <corners android:radius="8dp"/>
        </shape>
    </item>

</selector>